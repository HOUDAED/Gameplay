<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<AnchorPane
        prefHeight="600.0" prefWidth="900.0"
        style="-fx-background-color: #08060f;"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.zukuk.controller.VictoireController">

    <Circle centerX="150" centerY="80"  radius="1.2" fill="white" opacity="0.5"/>
    <Circle centerX="400" centerY="40"  radius="0.8" fill="white" opacity="0.7"/>
    <Circle centerX="700" centerY="60"  radius="1.0" fill="white" opacity="0.4"/>
    <Circle centerX="850" centerY="30"  radius="1.2" fill="white" opacity="0.6"/>
    <Circle centerX="250" centerY="120" radius="0.8" fill="white" opacity="0.3"/>
    <Circle centerX="600" centerY="90"  radius="1.0" fill="white" opacity="0.5"/>

    <VBox alignment="CENTER" spacing="28"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
          style="-fx-padding: 40 80 40 80;">

        <Label text="ZUKUK  //  MISSION ACCOMPLIE"
               style="-fx-text-fill: rgba(76,175,80,0.3);
                      -fx-font-size: 10px;
                      -fx-font-family: 'Georgia';
                      -fx-font-style: italic;"/>

        <Line startX="0" endX="200" stroke="#4caf50" strokeWidth="1" opacity="0.4"/>

        <ImageView fx:id="imageVictoire"
                   fitWidth="260" fitHeight="180"
                   preserveRatio="true"
                   style="-fx-effect: dropshadow(gaussian, #4caf50, 24, 0.3, 0, 0);"/>

        <Label text="LA BOMBE A ÉTÉ DÉSAMORCÉE"
               style="-fx-text-fill: #4caf50;
                      -fx-font-size: 22px;
                      -fx-font-family: 'Georgia';
                      -fx-font-weight: bold;"/>

        <Label text="La ville est sauvée. Vous avez accompli l'impossible."
               style="-fx-text-fill: rgba(255,255,255,0.5);
                      -fx-font-size: 14px;
                      -fx-font-family: 'Georgia';
                      -fx-font-style: italic;"/>

        <Line startX="0" endX="200" stroke="#4caf50" strokeWidth="1" opacity="0.3"/>

        <HBox spacing="20" alignment="CENTER">
            <Button text="REJOUER"
                    onAction="#handleRejouer"
                    style="-fx-background-color: transparent;
                           -fx-border-color: #4caf50;
                           -fx-border-width: 1px;
                           -fx-text-fill: #4caf50;
                           -fx-font-size: 12px;
                           -fx-font-family: 'Georgia';
                           -fx-padding: 10 36 10 36;
                           -fx-cursor: hand;"/>
            <Button text="QUITTER"
                    onAction="#handleQuitter"
                    style="-fx-background-color: transparent;
                           -fx-border-color: rgba(255,255,255,0.2);
                           -fx-border-width: 1px;
                           -fx-text-fill: rgba(255,255,255,0.3);
                           -fx-font-size: 12px;
                           -fx-font-family: 'Georgia';
                           -fx-padding: 10 36 10 36;
                           -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <Line startX="0" endX="900" layoutY="599"
          stroke="#4caf50" strokeWidth="1" opacity="0.3"/>
</AnchorPane>

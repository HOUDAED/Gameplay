<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane
        prefHeight="600.0"
        prefWidth="900.0"
        style="-fx-background-color: #0a0612;"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.zukuk.controller.MenuController">

    <children>

        <Rectangle
                layoutX="0" layoutY="440"
                width="900" height="160"
                fill="#1a0f2e" />

        <Rectangle
                layoutX="0" layoutY="520"
                width="900" height="80"
                fill="#120a22" />

        <Line
                startX="0" endX="900"
                layoutY="440"
                stroke="#ff3c3c"
                strokeWidth="1.5"
                opacity="0.5" />

        <VBox
                fx:id="rootPane"
                alignment="CENTER"
                spacing="16.0"
                AnchorPane.topAnchor="60"
                AnchorPane.bottomAnchor="160"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0">

            <children>

                <Label
                        text="ZUKUK"
                        style="-fx-text-fill: white;
                           -fx-font-size: 72px;
                           -fx-font-weight: bold;
                           -fx-font-family: 'Georgia';
                           -fx-effect: dropshadow(gaussian, #ff3c3c, 20, 0.3, 0, 0);" />

                <Label
                        text="escape game  ·  quiz de survie"
                        style="-fx-text-fill: rgba(255,255,255,0.3);
                           -fx-font-size: 13px;
                           -fx-font-family: 'Georgia';
                           -fx-font-style: italic;" />

                <Line
                        startX="-50" endX="50"
                        stroke="#ff3c3c"
                        strokeWidth="1"
                        opacity="0.5" />

                <Button
                        fx:id="btnNouvelle"
                        text="NOUVELLE PARTIE"
                        onAction="#handleNouvelle"
                        style="-fx-background-color: transparent;
                           -fx-border-color: rgba(255,60,60,0.65);
                           -fx-border-width: 1px;
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-family: 'Georgia';
                           -fx-padding: 14 60 14 60;
                           -fx-cursor: hand;" />

                <Button
                        fx:id="btnReprendre"
                        text="REPRENDRE LA PARTIE"
                        onAction="#handleReprendre"
                        style="-fx-background-color: transparent;
                           -fx-border-color: rgba(255,255,255,0.18);
                           -fx-border-width: 1px;
                           -fx-text-fill: rgba(255,255,255,0.45);
                           -fx-font-size: 12px;
                           -fx-font-family: 'Georgia';
                           -fx-padding: 10 60 10 60;
                           -fx-cursor: hand;" />

                <Button
                        fx:id="btnQuitter"
                        text="QUITTER"
                        onAction="#handleQuitter"
                        style="-fx-background-color: transparent;
                           -fx-border-color: transparent;
                           -fx-text-fill: rgba(255,255,255,0.2);
                           -fx-font-size: 11px;
                           -fx-font-family: 'Georgia';
                           -fx-padding: 6 20 6 20;
                           -fx-cursor: hand;" />

            </children>
        </VBox>

    </children>
</AnchorPane>